# ============================================================
# Celo GovAI Hub — Environment Variables
# "Be up-to-date on the Celo Blockchain"
# ============================================================

# --- Required ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# Bot @username without @ — Share & Earn deep links (defaults in code if unset)
# BOT_USERNAME=GovAIHub_bot

# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Your Telegram numeric chat ID (use @userinfobot to find it)
ADMIN_CHAT_ID=123456789

# --- Optional (defaults shown) ---
# Celo RPC — default: Forno (free, no key required)
CELO_RPC_URL=https://forno.celo.org

# Nitter instance for Twitter/X RSS
NITTER_INSTANCE=https://nitter.net

# CoinGecko API key — optional, higher rate limits (demo header on api.coingecko.com)
# Get from https://www.coingecko.com/en/api
COINGECKO_API_KEY=
# Optional: set to https://pro-api.coingecko.com/api/v3 if you use a Pro key
# COINGECKO_API_BASE=
# Comma-separated vs_currencies for /simple/price (stablecoin multi-fiat spot lines)
# COINGECKO_FIAT_CURRENCIES=usd,eur,brl,gbp,mxn
# In-process cache TTL for CoinGecko bundles (seconds)
# COINGECKO_CACHE_TTL_SEC=600

# Fiat on-ramps (AI Trade keyboard when stablecoins appear in suggestions)
# Transak partner key — required for Transak URL params to apply: https://docs.transak.com/
TRANSAK_API_KEY=
# Ramp host API key — https://docs.ramp.network/
RAMP_HOST_API_KEY=
# ISO 4217 defaults for widget pre-selection
# DEFAULT_ONRAMP_FIAT=USD
# DEFAULT_RAMP_FIAT=EUR

# Bot wallet — receives cUSD payments and signs ERC-8004 registration
# Generate: python -c "from web3 import Web3; a=Web3().eth.account.create(); print(a.address, a.key.hex())"
BOT_WALLET_ADDRESS=0x...
BOT_WALLET_PRIVATE_KEY=0x...
# ⚠️ NEVER commit BOT_WALLET_PRIVATE_KEY to Git

# Governance wallet — the wallet that receives vote delegations from users (bot agent).
# Used exclusively by GovernanceExecutor to sign on-chain vote transactions.
# Must match the address registered as delegate on the Celo Governance contract.
# Generate a dedicated wallet (separate from BOT_WALLET) for better security isolation.
GOVERNANCE_DELEGATE_ADDRESS=0x...
GOVERNANCE_PRIVATE_KEY=0x...
# Gas multiplier over current network fee (EIP-1559 base fee or legacy gasPrice fallback).
GAS_PRICE_MULTIPLIER=2.0
# ⚠️ NEVER commit GOVERNANCE_PRIVATE_KEY to Git

# DAO treasury — multi-sig payout quorum (P10)
TREASURY_ADDRESS=0x...        # DAO treasury wallet address
TREASURY_QUORUM=2             # Minimum number of admin approvals required

# ── Database ──────────────────────────────────────────────────────────
# Production: get the POOLED connection string from Neon dashboard
#   1. Go to https://console.neon.tech → your project
#   2. Click "Connection Details" → toggle "Pooled connection" ON
#   3. Copy the string (format below) and paste here
# Local dev: leave blank to use SQLite fallback
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Logging (P39) ─────────────────────────────────────────────────────────────
# Production (Render): set LOG_TO_FILE=false (console only). Local: true = console + files
LOG_LEVEL=INFO
LOG_TO_FILE=true

# ── Scheduler (digest time) ───────────────────────────────────────────────────
# Timezone for daily digest — must match config.yaml digest_schedule.timezone
DIGEST_SCHEDULE_TIMEZONE=Europe/Madrid

TREASURY_ADDRESS=0x...        # DAO treasury wallet address
TREASURY_QUORUM=2       

# ── Transaction history — Etherscan V2 (single key covers Celo via chainid=42220) ──
# Get your key at: https://etherscan.io/myapikey
# Optional — used by src/utils/etherscan_v2.py for address tx lists (e.g. future wallet UX).
ETHERSCAN_API_KEY=YourEtherscanApiKeyHere
ETHERSCAN_V2_URL=https://api.etherscan.io/v2/api
CELO_CHAIN_ID=42220

# ── Transaction history — Blockscout Celo (no API key; fallback when Etherscan fails) ──
# Blockscout REST API v2 — no API key required
# Primary: Celo Mainnet
BLOCKSCOUT_CELO_URL=https://celo.blockscout.com/api/v2
# Fallback: Alfajores testnet (used when user network = alfajores)
BLOCKSCOUT_ALFAJORES_URL=https://alfajores.blockscout.com/api/v2
# Legacy alias (optional): BLOCKSCOUT_CELO_ALFAJORES_URL — still read if set
# NOTE: never use ?limit= param — Blockscout v2 returns 422. Truncate in Python.
