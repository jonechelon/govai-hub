# ============================================================
# Celo GovAI Hub — Environment Variables
# "Be up-to-date on the Celo Blockchain"
# ============================================================

# --- Required ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Your Telegram numeric chat ID (use @userinfobot to find it)
ADMIN_CHAT_ID=123456789

# --- Optional (defaults shown) ---
# Celo RPC — default: Forno (free, no key required)
CELO_RPC_URL=https://forno.celo.org

# Nitter instance for Twitter/X RSS
NITTER_INSTANCE=https://nitter.net

# CoinGecko API key — optional, increases rate limit
# Get from https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Bot wallet — receives cUSD payments and signs ERC-8004 registration
# Generate: python -c "from web3 import Web3; a=Web3().eth.account.create(); print(a.address, a.key.hex())"
BOT_WALLET_ADDRESS=0x...
BOT_WALLET_PRIVATE_KEY=0x...
# ⚠️ NEVER commit BOT_WALLET_PRIVATE_KEY to Git

# ── Database ──────────────────────────────────────────────────────────
# Production: get the POOLED connection string from Neon dashboard
#   1. Go to https://console.neon.tech → your project
#   2. Click "Connection Details" → toggle "Pooled connection" ON
#   3. Copy the string (format below) and paste here
# Local dev: leave blank to use SQLite fallback
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Logging (P39) ─────────────────────────────────────────────────────────────
# Production (Render): set LOG_TO_FILE=false (console only). Local: true = console + files
LOG_LEVEL=INFO
LOG_TO_FILE=true

# ── Scheduler (digest time) ───────────────────────────────────────────────────
# Timezone for daily digest — must match config.yaml digest_schedule.timezone
DIGEST_SCHEDULE_TIMEZONE=Europe/Madrid
